t-install-checklist"},{"type":"doc","id":"getting-started/setup-wizard"}]},{"type":"doc","id":"troubleshooting/index","label":"Troubleshooting"},{"type":"category","label":"usage","collapsible":true,"collapsed":true,"items":[{"type":"doc","id":"usage/post-types"},{"type":"doc","id":"usage/shortcodes"}]}]}}]}},"docusaurus-plugin-content-blog":{"default":{"blogSidebarTitle":"Recent posts","blogPosts":[{"id":"v4-5-5-released","metadata":{"permalink":"/mhm-rentiva-docs/blog/v4-5-5-released","editUrl":"https://github.com/MaxHandMade/mhm-rentiva/tree/main/website/blog/2026-01-15-v4-5-5-released.md","source":"@site/blog/2026-01-15-v4-5-5-released.md","title":"v4.5.5 Yayında! 🚀","description":"MHM Rentiva v4.5.5 sürümü yayınlandı! Bu sürüm, kararlılık iyileştirmeleri, kritik performans düzeltmeleri ve dokümantasyon altyapısında büyük yenilikler içeriyor.","date":"2026-01-15T00:00:00.000Z","tags":[{"inline":true,"label":"release","permalink":"/mhm-rentiva-docs/blog/tags/release"},{"inline":true,"label":"update","permalink":"/mhm-rentiva-docs/blog/tags/update"},{"inline":true,"label":"v4.5.5","permalink":"/mhm-rentiva-docs/blog/tags/v-4-5-5"}],"readingTime":0.64,"hasTruncateMarker":true,"authors":[{"name":"MaxHandMade","title":"Maintainer","url":"https://github.com/MaxHandMade","imageURL":"https://github.com/MaxHandMade.png","key":"maxhandmade","page":null}],"frontMatter":{"slug":"v4-5-5-released","title":"v4.5.5 Yayında! 🚀","authors":["maxhandmade"],"tags":["release","update","v4.5.5"],"date":"2026-01-15T00:00:00.000Z"},"unlisted":false},"content":"MHM Rentiva **v4.5.5** sürümü yayınlandı! Bu sürüm, kararlılık iyileştirmeleri, kritik performans düzeltmeleri ve dokümantasyon altyapısında büyük yenilikler içeriyor.\r\n\r\n<!--truncate-->\r\n\r\n## 🌟 Öne Çıkanlar\r\n\r\n*   **Güvenlik & Mimari:** Plugin kaynak kodları artık Private bir repoda korunurken, dokümantasyon (bu site) Public bir repoda herkesin erişimine açık hale getirildi.\r\n*   **Performans:** Raporlama modülündeki SQL sorguları, `DATE()` fonksiyonu kaldırılarak indeks kullanımına uygun hale getirildi. Artık çok daha hızlı çalışıyor.\r\n*   **Mobil Uyumluluk:** Araç detay sayfaları mobilde artık taşma yapmıyor, butonlar ve görseller tam uyumlu.\r\n\r\n## 🛠️ Düzeltmeler\r\n\r\n*   **Fixed:** `Plugin.php` içindeki mükerrer kodlar temizlendi.\r\n*   **Fixed:** `ReportRepository` sınıfındaki yavaş sorgular optimize edildi.\r\n*   **Fixed:** Araç kıyaslama sayfasındaki hizalama sorunları giderildi.\r\n*   **Fixed:** \"Hizmete Kapalı\" (Out of Use) etiketi artık varyasyonlu ürünlerde de doğru çalışıyor.\r\n\r\n## 📦 Yükseltme\r\n\r\nWordPress panelinizden otomatik güncelleme yapabilirsiniz. Herhangi bir sorun yaşarsanız lütfen GitHub üzerinden veya destek sayfamızdan bize ulaşın.\r\n\r\nKeyifli kiralamalar! 🚗💨"}],"blogListPaginated":[{"items":["v4-5-5-released"],"metadata":{"permalink":"/mhm-rentiva-docs/blog","page":1,"postsPerPage":10,"totalPages":1,"totalCount":1,"blogDescription":"Blog","blogTitle":"Blog"}}],"blogTags":{"/mhm-rentiva-docs/blog/tags/release":{"inline":true,"label":"release","permalink":"/mhm-rentiva-docs/blog/tags/release","items":["v4-5-5-released"],"pages":[{"items":["v4-5-5-released"],"metadata":{"permalink":"/mhm-rentiva-docs/blog/tags/release","page":1,"postsPerPage":10,"totalPages":1,"totalCount":1,"blogDescription":"Blog","blogTitle":"Blog"}}],"unlisted":false},"/mhm-rentiva-docs/blog/tags/update":{"inline":true,"label":"update","permalink":"/mhm-rentiva-docs/blog/tags/update","items":["v4-5-5-released"],"pages":[{"items":["v4-5-5-released"],"metadata":{"permalink":"/mhm-rentiva-docs/blog/tags/update","page":1,"postsPerPage":10,"totalPages":1,"totalCount":1,"blogDescription":"Blog","blogTitle":"Blog"}}],"unlisted":false},"/mhm-rentiva-docs/blog/tags/v-4-5-5":{"inline":true,"label":"v4.5.5","permalink":"/mhm-rentiva-docs/blog/tags/v-4-5-5","items":["v4-5-5-released"],"pages":[{"items":["v4-5-5-released"],"metadata":{"permalink":"/mhm-rentiva-docs/blog/tags